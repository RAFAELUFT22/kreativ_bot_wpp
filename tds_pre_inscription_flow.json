            "isLong": true,
            "placeholder": "Participação em políticas públicas"
          }
        },
        {
          "id": "webhookBlock",
          "type": "webhook",
          "label": "Enviar Dados",
          "webhook": {
            "url": "https://n8n.example.com/webhook/tds",
            "method": "POST",
            "headers": [],
            "queryParams": [],
            "body": "{{{\n  \"action\": \"submit_tds_form\",\n  \"data\": {\n    \"nome\": \"{{nomeInput}}\",\n    \"cpf\": \"{{cpfInput}}\",\n    \"municipio\": \"{{municipioInput}}\",\n    \"sexo\": \"{{sexoChoice}}\",\n    \"idade\": \"{{idadeInput}}\",\n    \"escolaridade\": \"{{escolaridadeChoice}}\",\n    \"cadUnico\": \"{{cadUnicoChoice}}\",\n    \"beneficios\": \"{{beneficiosInput}}\",\n    \"infraestrutura\": \"{{infraestruturaInput}}\",\n    \"rendaPessoal\": \"{{rendaPessoalChoice}}\",\n    \"rendaFamiliar\": \"{{rendaFamiliarInput}}\",\n    \"atividade\": \"{{atividadeChoice}}\",\n    \"credito\": \"{{creditoInput}}\",\n    \"politicas\": \"{{politicasInput}}\"\n  }\n}}}"
          }
        }
      ]
    }
  ],
