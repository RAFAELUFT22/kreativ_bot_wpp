{
  "groups": [
    {
      "id": "group1",
      "title": "Formulário TDS",
      "blocks": [
        {
          "id": "startBlock",
          "type": "start",
          "label": "Início"
        },
        {
          "id": "identificacaoBlock",
          "type": "text",
          "label": "Identificação",
          "content": {
            "richText": {
              "children": [
                {
                  "text": "Vamos começar com sua identificação. Preencha os dados abaixo:"
                }
              ]
            }
          }
        },
        {
          "id": "nomeInput",
          "type": "text",
          "label": "Nome",
          "options": {
            "isLong": false,
            "placeholder": "Digite seu nome completo"
          }
        },
        {
          "id": "cpfInput",
          "type": "text",
          "label": "CPF",
          "options": {
            "isLong": false,
            "placeholder": "Digite seu CPF (apenas números)",
            "mask": "999.999.999-99"
          }
        },
        {
          "id": "municipioInput",
          "type": "text",
          "label": "Município",
          "options": {
            "isLong": false,
            "placeholder": "Digite seu município"
          }
        },
        {
          "id": "perfilBlock",
          "type": "text",
          "label": "Perfil",
          "content": {
            "richText": {
              "children": [
                {
                  "text": "Agora, informe seu perfil:"
                }
              ]
            }
          }
        },
        {
          "id": "sexoChoice",
          "type": "Choice",
          "label": "Sexo",
          "items": [
            {
              "id": "masculino",
              "content": "Masculino"
            },
            {
              "id": "feminino",
              "content": "Feminino"
            },
            {
              "id": "outro",
              "content": "Outro"
            }
          ]
        },
        {
          "id": "idadeInput",
          "type": "text",
          "label": "Idade",
          "options": {
            "isLong": false,
            "placeholder": "Digite sua idade"
          }
        },
        {
          "id": "escolaridadeChoice",
          "type": "Choice",
          "label": "Escolaridade",
          "items": [
            {
              "id": "fundamental",
              "content": "Fundamental Incompleto"
            },
            {
              "id": "medio",
              "content": "Médio Completo"
            },
            {
              "id": "superior",
              "content": "Superior Completo"
            },
            {
              "id": "pos",
              "content": "Pós-graduação"
            }
          ]
        },
        {
          "id": "socialBlock",
          "type": "text",
          "label": "Social",
          "content": {
            "richText": {
              "children": [
                {
                  "text": "Informações sociais:"
                }
              ]
            }
          }
        },
        {
