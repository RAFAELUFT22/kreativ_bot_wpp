# =============================================================================
# .env.frappe — Variáveis para o Frappe LMS
# Copiar para .env.frappe e JAMAIS commitar o arquivo com senhas reais
# =============================================================================

# --- MariaDB ---
MARIADB_ROOT_PASSWORD=troque_por_senha_forte_aqui
MARIADB_FRAPPE_PASSWORD=troque_por_senha_frappe_aqui

# --- Frappe Site ---
FRAPPE_SITE_NAME=lms.extensionista.site
FRAPPE_ADMIN_PASSWORD=troque_por_senha_admin_aqui

# --- API Keys (geradas após setup via bench) ---
# Preencher após executar: scripts/setup_frappe_lms.sh
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# --- Integração N8N ---
# Estes valores ficam no .env principal do stack também
FRAPPE_LMS_URL=https://lms.extensionista.site
