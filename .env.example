# =============================================================================
# KREATIV EDUCACAO — Environment Variables Template
# Copy to .env and fill in actual values before deploying
# =============================================================================

# PostgreSQL
POSTGRES_USER=kreativ_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kreativ_edu

# Redis
REDIS_PASSWORD=changeme

# Evolution API (WhatsApp)
EVOLUTION_API_KEY=changeme
EVOLUTION_DB=evolution_db

# N8N (Workflow Automation)
N8N_API_KEY=changeme
N8N_ENCRYPTION_KEY=changeme
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# Typebot (Bot Builder)
TYPEBOT_ENCRYPTION_SECRET=changeme
TYPEBOT_NEXTAUTH_SECRET=changeme
TYPEBOT_ADMIN_EMAIL=admin@extensionista.site

# MinIO (Object Storage)
MINIO_ROOT_USER=kreativ
MINIO_ROOT_PASSWORD=changeme

# Chatwoot (CRM/Support)
CHATWOOT_SECRET_KEY_BASE=changeme

# ToolJet (Admin Panel)
LOCKBOX_KEY=changeme
TOOLJET_SECRET_KEY=changeme

# Metabase (Analytics)
METABASE_API_KEY=changeme

# AI APIs
DEEPSEEK_API_KEY=changeme
OPEN_ROUTER_API=changeme

# Portal (Next.js)
DB_HOST=kreativ_postgres
DB_PORT=5432
DB_NAME=kreativ_edu
DB_USER=kreativ_user
DB_PASSWORD=changeme
NEXT_PUBLIC_SUPPORT_PHONE=556399374165
NEXT_PUBLIC_CHATWOOT_TOKEN=changeme
