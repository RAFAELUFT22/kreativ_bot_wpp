        {
            "parameters": {
                "jsCode": "// ============================================================\n// MENU PRINCIPAL — Montar mensagem com botões interativos\n// ============================================================\nconst student = $('Unified API — check_student').first().json;\nconst pushName = $('Session Manager').first().json.pushName;\nconst phone = $('Session Manager').first().json.phone;\nconst instanceName = $('Session Manager').first().json.instanceName;\n\nconst isEnrolled = student?.student_id || student?.found;\nconst studentName = student?.name || pushName || 'Aluno';\nconst moduleCurrent = student?.current_module_title || 'Módulo 1';\n\nlet greeting = '';\nconst hour = new Date().getHours();\nif (hour < 12) greeting = '🌅 Bom dia';\nelse if (hour < 18) greeting = '☀️ Boa tarde';\nelse greeting = '🌙 Boa noite';\n\nif (!isEnrolled) {\n  // Aluno não cadastrado\n  return [{\n    json: {\n      phone, instanceName,\n      textMessage: `${greeting}, ${pushName || 'seja bem-vindo'}! 👋\\n\\nSou o *Kre*, assistente educacional da *Kreativ Educação* 🎓\\n\\nPara começar sua jornada de aprendizado, preciso verificar seu cadastro.\\n\\nEntre em contato com nossa equipe:\\n📞 (63) 9937-4165\\n🌐 lms.extensionista.site`,\n      sessionUpdate: { state: 'new', studentId: null }\n    }\n  }];\n}\n\n// Aluno cadastrado — menu principal com botões\nreturn [{\n  json: {\n    phone, instanceName,\n    useButtons: true,\n    textMessage: `${greeting}, *${studentName}*! 🎓\\n\\n📚 *Módulo atual:* ${moduleCurrent}\\n\\nO que você quer fazer hoje?`,\n    buttons: [\n      { buttonId: 'estudar', buttonText: { displayText: '📖 Estudar Módulo' }, type: 1 },\n      { buttonId: 'progresso', buttonText: { displayText: '📊 Meu Progresso' }, type: 1 },\n      { buttonId: 'tutor', buttonText: { displayText: '🤝 Falar com Tutor' }, type: 1 }\n    ],\n    sessionUpdate: {\n      state: 'menu',\n      studentId: student.student_id || student.id,\n      currentModuleId: student.current_module_id\n    }\n  }\n}];"
            },
