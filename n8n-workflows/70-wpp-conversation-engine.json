                "jsCode": "// ============================================================\n// HANDLE QUIZ — Avaliar resposta do aluno com DeepSeek\n// ============================================================\nconst session = $('Session Manager').first().json;\nconst phone = session.phone;\nconst instanceName = session.instanceName;\nconst quizData = session.quizData || {};\nconst userAnswer = session.messageText;\n\nreturn [{\n  json: {\n    phone, instanceName,\n    action: 'submit_quiz',\n    userAnswer,\n    quizData,\n    textMessage: '⏳ Avaliando sua resposta...',\n    sessionUpdate: { state: 'menu', waitingQuizAnswer: false }\n  }\n}];"
