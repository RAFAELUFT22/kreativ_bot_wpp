        },
        {
            "parameters": {
                "jsCode": "// ============================================================\n// SESSION MANAGER — Determina estado atual do aluno\n// ============================================================\nconst sessionRaw = $('Redis — Ler sessão').first()?.json?.value;\nlet session = {};\n\ntry {\n  session = sessionRaw ? JSON.parse(sessionRaw) : {};\n} catch (e) {\n  session = {};\n}\n\nconst phone = $('Normalizar Payload Evolution').first().json.phone;\nconst messageText = $('Normalizar Payload Evolution').first().json.messageText;\nconst messageType = $('Normalizar Payload Evolution').first().json.messageType;\nconst pushName = $('Normalizar Payload Evolution').first().json.pushName;\nconst instanceName = $('Normalizar Payload Evolution').first().json.instanceName;\n\n// Estado atual da sessão\nconst currentState = session.state || 'new';\nconst studentId = session.studentId || null;\nconst currentModuleId = session.currentModuleId || null;\nconst waitingQuizAnswer = session.waitingQuizAnswer || false;\nconst quizData = session.quizData || null;\n\n// Saudações que iniciam ou reiniciam o fluxo\nconst startTriggers = ['oi', 'olá', 'ola', 'hello', 'hi', 'menu', 'inicio', 'início', 'começar', 'comecar'];\nconst isStart = startTriggers.includes(messageText.toLowerCase());\n\nreturn [{\n  json: {\n    phone,\n    pushName,\n    instanceName,\n    messageText,\n    messageType,\n    currentState: isStart ? 'greeting' : currentState,\n    studentId,\n    currentModuleId,\n    waitingQuizAnswer,\n    quizData,\n    session\n  }\n}];"
            },
            "id": "session-manager",
            "name": "Session Manager",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1100,
