        {
            "parameters": {
                "jsCode": "// ============================================================\n// NORMALIZAR PAYLOAD DO EVOLUTION API\n// ============================================================\nconst body = $json.body || $json;\nconst event = body.event || '';\n\n// Ignorar eventos que não são mensagens\nif (!['MESSAGES_UPSERT', 'messages.upsert'].includes(event)) {\n  return [{ json: { skip: true, reason: `Evento ignorado: ${event}` } }];\n}\n\nconst data = body.data || {};\nconst msg = data.message || data.messages?.[0] || {};\nconst key = msg.key || data.key || {};\n\n// Ignorar mensagens do próprio bot (fromMe)\nif (key.fromMe === true) {\n  return [{ json: { skip: true, reason: 'fromMe=true' } }];\n}\n\nconst remoteJid = key.remoteJid || '';\nconst phone = remoteJid.replace('@s.whatsapp.net', '').replace('@c.us', '');\nconst pushName = msg.pushName || data.pushName || '';\nconst instanceName = body.instance || data.instance || 'europs';\n\n// Extrair texto da mensagem (vários formatos possíveis)\nlet messageText = '';\nlet messageType = 'text';\n\nif (msg.message?.conversation) {\n  messageText = msg.message.conversation;\n} else if (msg.message?.extendedTextMessage?.text) {\n  messageText = msg.message.extendedTextMessage.text;\n} else if (msg.message?.interactiveResponseMessage?.body?.text) {\n  // Resposta de botão interativo\n  messageText = msg.message.interactiveResponseMessage.body.text;\n  messageType = 'button_reply';\n} else if (msg.message?.buttonsResponseMessage?.selectedButtonId) {\n  messageText = msg.message.buttonsResponseMessage.selectedDisplayText || msg.message.buttonsResponseMessage.selectedButtonId;\n  messageType = 'button_reply';\n} else if (msg.message?.listResponseMessage?.singleSelectReply?.selectedRowId) {\n  messageText = msg.message.listResponseMessage.singleSelectReply.selectedRowId;\n  messageType = 'list_reply';\n} else if (msg.message?.audioMessage) {\n  messageType = 'audio';\n  messageText = '[audio]';\n}\n\nif (!phone || !messageText) {\n  return [{ json: { skip: true, reason: 'Sem telefone ou mensagem' } }];\n}\n\nreturn [{\n  json: {\n    phone,\n    remoteJid,\n    pushName,\n    instanceName,\n    messageText: messageText.trim(),\n    messageType,\n    timestamp: Date.now()\n  }\n}];"
            },
            "id": "normalize-payload",
            "name": "Normalizar Payload Evolution",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                440,
                0
            ]
        },
        {
            "parameters": {
